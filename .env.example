# VerumOS 环境变量配置

# ===========================================
# 必填配置
# ===========================================

# LLM API 配置（中转站）
# 必填：用于 LLM 功能（意图识别、对话等）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=http://35.220.164.252:3888/v1/

# Python 路径（用于执行数据处理脚本）
# 必填：用于 csv-skill 和 bioinfo-skill
PYTHON_PATH=/opt/homebrew/Caskroom/miniconda/base/bin/python

# ===========================================
# 可选配置（有默认值）
# ===========================================

# LLM 模型名称
LLM_MODEL=glm-5

# 服务端口
PORT=3000

# 数据目录
DATA_DIR=./data